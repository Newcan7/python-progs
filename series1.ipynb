   "source": [
    "def series(a):\n",
    "    temp=a*(a+1)\n",
    "    return temp\n",
    "\n",
    "n = int(input('enter limit'))\n",
    "sum=0\n",
    "i=1\n",
    "while i<=n :\n",
    "    sum= sum+ series(i)\n",
    "    i=i+1\n",
    "print(sum)"
   ]
