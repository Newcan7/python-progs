    "def series(a):\n",
    "    temp=(1/a)\n",
    "    return temp\n",
    "\n",
    "n = int(input('enter limit'))\n",
    "sum=0\n",
    "for i in range(1,n+1):\n",
    "    sum= sum+ series(i)\n",
    "print(sum)"
